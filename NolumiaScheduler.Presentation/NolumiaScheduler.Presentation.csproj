<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<RootNamespace>NolumiaScheduler</RootNamespace>
		<UseMaui>true</UseMaui>
		<MauiXamlInflator>SourceGen</MauiXamlInflator>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Maui.Controls" Version="$(MauiVersion)" />
		<PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="10.0.0" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\NolumiaScheduler.Application\NolumiaScheduler.Application.csproj" />
		<ProjectReference Include="..\NolumiaScheduler.Domain\NolumiaScheduler.Domain.csproj" />
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Update="Resources\Strings\AppResources.resx">
			<LogicalName>NolumiaScheduler.Resources.Strings.AppResources.resources</LogicalName>
		</EmbeddedResource>
		<EmbeddedResource Update="Resources\Strings\AppResources.ja.resx">
			<LogicalName>NolumiaScheduler.Resources.Strings.AppResources.ja.resources</LogicalName>
			<Culture>ja</Culture>
		</EmbeddedResource>
	</ItemGroup>

	<ItemGroup>
		<MauiXaml Update="Presentation\Pages\AlarmDebugPage.xaml">
			<Generator>MSBuild:Compile</Generator>
		</MauiXaml>
		<MauiXaml Update="Presentation\Pages\AlarmNotificationOverlay.xaml">
			<Generator>MSBuild:Compile</Generator>
		</MauiXaml>
		<MauiXaml Update="Presentation\Pages\AlarmPage.xaml">
			<Generator>MSBuild:Compile</Generator>
		</MauiXaml>
	</ItemGroup>

</Project>
