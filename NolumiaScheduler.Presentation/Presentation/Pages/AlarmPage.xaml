<?xml version="1.0" encoding="utf-8" ?>
<Window xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        x:Class="NolumiaScheduler.Presentation.Pages.AlarmPage"
        Title="Alarm">

    <ContentPage BackgroundColor="#1A1A2E"
                 Shell.NavBarIsVisible="False"
                 Shell.TabBarIsVisible="False">
        <Grid VerticalOptions="Fill" HorizontalOptions="Fill">
            <BoxView Color="#1A1A2E" />

            <VerticalStackLayout
                Spacing="24"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Padding="40">

                <!-- Title -->
                <Label
                    x:Name="TitleLabel"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalTextAlignment="Center" />

                <!-- Message -->
                <Label
                    x:Name="MessageLabel"
                    FontSize="20"
                    TextColor="#CCFFFFFF"
                    HorizontalTextAlignment="Center" />

                <!-- Action buttons -->
                <VerticalStackLayout Spacing="12" WidthRequest="320">
                    <Button
                        x:Name="Snooze5Button"
                        FontSize="16"
                        HeightRequest="50"
                        CornerRadius="25"
                        BackgroundColor="#6366F1"
                        TextColor="White"
                        Clicked="OnSnooze5Clicked" />

                    <Button
                        x:Name="Snooze1Button"
                        FontSize="16"
                        HeightRequest="50"
                        CornerRadius="25"
                        BackgroundColor="#4F46E5"
                        TextColor="White"
                        Clicked="OnSnooze1Clicked" />

                    <Button
                        x:Name="DismissButton"
                        FontSize="16"
                        HeightRequest="50"
                        CornerRadius="25"
                        BackgroundColor="Transparent"
                        BorderColor="#6366F1"
                        BorderWidth="2"
                        TextColor="#A5B4FC"
                        Clicked="OnDismissClicked" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>
    </ContentPage>
</Window>
