<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="NolumiaScheduler.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:NolumiaScheduler.Presentation.Pages"
    xmlns:res="clr-namespace:NolumiaScheduler.Resources.Strings"
    Title="NolumiaScheduler">

    <TabBar>
        <ShellContent
            Title="{x:Static res:AppResources.CalendarTab}"
            ContentTemplate="{DataTemplate pages:CalendarPage}"
            Route="CalendarPage" />

        <ShellContent
            Title="{x:Static res:AppResources.BusinessCalendarsTab}"
            ContentTemplate="{DataTemplate pages:BusinessCalendarListPage}"
            Route="BusinessCalendarListPage" />
    </TabBar>

</Shell>
