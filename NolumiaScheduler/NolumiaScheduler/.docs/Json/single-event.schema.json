{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/single-event.schema.json",
  "title": "Single Event",
  "allOf": [
    {
      "$ref": "./common.schema.json#/$defs/commonEventFields"
    },
    {
      "type": "object",
      "properties": {
        "kind": {
          "const": "Single"
        },
        "start": {
          "$ref": "./common.schema.json#/$defs/offsetDateTime"
        },
        "end": {
          "$ref": "./common.schema.json#/$defs/offsetDateTime"
        }
      },
      "required": ["start", "end"],
      "additionalProperties": false
    }
  ]
}