{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/business-calendar.schema.json",
  "title": "Business Calendar",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "timezone": {
      "$ref": "./common.schema.json#/$defs/timezone"
    },
    "workdaysOfWeek": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/weekday"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "holidays": {
      "type": "array",
      "items": {
        "$ref": "./common.schema.json#/$defs/holiday"
      }
    }
  },
  "required": ["id", "name", "timezone", "workdaysOfWeek", "holidays"],
  "additionalProperties": false
}