<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NolumiaScheduler.Presentation.Pages.AlarmDebugPage"
             Title="アラームデバッグ">

    <Grid RowDefinitions="Auto,Auto,*" Padding="16">

        <!-- Header buttons -->
        <HorizontalStackLayout Grid.Row="0" Spacing="12" Margin="0,0,0,8">
            <Button Text="更新" Clicked="OnRefreshClicked" />
            <Button Text="テストアラーム表示" Clicked="OnTestAlarmClicked" />
            <Label x:Name="AutoRefreshLabel" Text="自動更新: 10秒" VerticalOptions="Center" FontSize="12" TextColor="Gray" />
        </HorizontalStackLayout>

        <!-- Diagnostics -->
        <Label x:Name="DiagLabel" Grid.Row="1" FontSize="12" TextColor="Gray" Margin="0,0,0,8" />

        <!-- Alarm list -->
        <CollectionView x:Name="AlarmList"
                        Grid.Row="2">
            <CollectionView.EmptyView>
                <Label Text="認識されているアラームはありません"
                       FontSize="14"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Margin="32" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                            StrokeShape="RoundRectangle 8"
                            Padding="12"
                            Margin="0,4">
                        <VerticalStackLayout Spacing="4">
                            <Label FontSize="15" FontAttributes="Bold">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Title}" />
                                        <Span Text="{Binding StatusBadge}"
                                              TextColor="{Binding StatusColor}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label Text="{Binding Detail}" FontSize="13" TextColor="Gray" />
                            <Label Text="{Binding NotifyAtText}" FontSize="12" TextColor="Gray" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
