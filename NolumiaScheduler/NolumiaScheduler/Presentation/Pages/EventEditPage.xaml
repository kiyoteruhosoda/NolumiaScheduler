<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NolumiaScheduler.Presentation.ViewModels"
             xmlns:res="clr-namespace:NolumiaScheduler.Resources.Strings"
             x:Class="NolumiaScheduler.Presentation.Pages.EventEditPage"
             x:DataType="vm:EventEditViewModel"
             Title="{Binding PageTitle}">

    <ScrollView BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurfaceVariant}, Dark={StaticResource GCalSurfaceVariantDark}}">
        <VerticalStackLayout Padding="16" Spacing="0">

            <!-- ── Validation error ── -->
            <Border IsVisible="{Binding HasValidationError}"
                    BackgroundColor="{AppThemeBinding Light=#fce8e6, Dark=#4a1c18}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    Padding="12,10"
                    Margin="0,0,0,12">
                <Label Text="{Binding ValidationError}"
                       FontSize="13"
                       TextColor="{StaticResource GCalRed}" />
            </Border>

            <!-- ── Title ── -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    Padding="12,0"
                    Margin="0,0,0,2">
                <Entry Text="{Binding Title}"
                       Placeholder="{x:Static res:AppResources.EventTitlePlaceholder}"
                       FontSize="16"
                       FontAttributes="Bold"
                       MinimumHeightRequest="52"
                       TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
            </Border>

            <!-- ── Location ── -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    Padding="12,0"
                    Margin="0,0,0,16">
                <Entry Text="{Binding Location}"
                       Placeholder="{x:Static res:AppResources.EventLocationPlaceholder}"
                       FontSize="14"
                       MinimumHeightRequest="48"
                       TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
            </Border>

            <!-- ── Date / Time ── -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    Padding="12,4"
                    Margin="0,0,0,16">
                <VerticalStackLayout Spacing="0">

                    <!-- All Day toggle -->
                    <Grid ColumnDefinitions="*,Auto" MinimumHeightRequest="48">
                        <Label Grid.Column="0" Text="{x:Static res:AppResources.AllDay}"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}"
                               VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding AllDay}" OnColor="{StaticResource GCalBlue}" />
                    </Grid>

                    <BoxView HeightRequest="0.5"
                             BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />

                    <!-- Start Date -->
                    <Grid ColumnDefinitions="Auto,*" MinimumHeightRequest="48">
                        <Label Grid.Column="0" Text="{x:Static res:AppResources.StartLabel}"
                               FontSize="14" WidthRequest="56"
                               TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                               VerticalOptions="Center" />
                        <DatePicker Grid.Column="1"
                                    Date="{Binding StartDate}"
                                    FontSize="14"
                                    TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}"
                                    MinimumHeightRequest="48" />
                    </Grid>

                    <!-- Start / End Time (hidden when AllDay) -->
                    <VerticalStackLayout IsVisible="{Binding ShowTimeSection}" Spacing="0">
                        <BoxView HeightRequest="0.5"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />
                        <Grid ColumnDefinitions="Auto,*,Auto,*" MinimumHeightRequest="48">
                            <Label Grid.Column="0" Text="{x:Static res:AppResources.StartLabel}"
                                   FontSize="13" WidthRequest="48"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                   VerticalOptions="Center" />
                            <TimePicker Grid.Column="1" Time="{Binding StartTime}" FontSize="14" Format="HH:mm"
                                        TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                            <Label Grid.Column="2" Text="{x:Static res:AppResources.EndLabel}"
                                   FontSize="13" WidthRequest="48"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                   VerticalOptions="Center" />
                            <TimePicker Grid.Column="3" Time="{Binding EndTime}" FontSize="14" Format="HH:mm"
                                        TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                        </Grid>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- ── Recurrence ── -->
            <Label Text="{x:Static res:AppResources.RepeatLabel}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                   Margin="4,0,0,4" />

            <Border BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    Padding="12,4"
                    Margin="0,0,0,4">
                <VerticalStackLayout Spacing="0">

                    <!-- Repeat type picker -->
                    <Picker ItemsSource="{Binding RepeatTypeItems}"
                            SelectedIndex="{Binding RepeatTypeIndex}"
                            FontSize="14"
                            MinimumHeightRequest="48"
                            TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />

                    <!-- ── Weekly section ── -->
                    <VerticalStackLayout IsVisible="{Binding IsWeekly}" Spacing="0">
                        <BoxView HeightRequest="0.5"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />
                        <Label Text="{x:Static res:AppResources.WeekdaysLabel}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                               Margin="0,8,0,4" />
                        <Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="4" Margin="0,0,0,8">
                            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{x:Static res:AppResources.DaySun}" FontSize="11"
                                       TextColor="{StaticResource GCalRed}" HorizontalOptions="Center" />
                                <CheckBox IsChecked="{Binding WeekSun}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{x:Static res:AppResources.DayMon}" FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                       HorizontalOptions="Center" />
                                <CheckBox IsChecked="{Binding WeekMon}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{x:Static res:AppResources.DayTue}" FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                       HorizontalOptions="Center" />
                                <CheckBox IsChecked="{Binding WeekTue}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{x:Static res:AppResources.DayWed}" FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                       HorizontalOptions="Center" />
                                <CheckBox IsChecked="{Binding WeekWed}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{x:Static res:AppResources.DayThu}" FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                       HorizontalOptions="Center" />
                                <CheckBox IsChecked="{Binding WeekThu}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="5" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{x:Static res:AppResources.DayFri}" FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                       HorizontalOptions="Center" />
                                <CheckBox IsChecked="{Binding WeekFri}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="6" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{x:Static res:AppResources.DaySat}" FontSize="11"
                                       TextColor="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                                <CheckBox IsChecked="{Binding WeekSat}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- ── Monthly section ── -->
                    <VerticalStackLayout IsVisible="{Binding IsMonthly}" Spacing="0">
                        <BoxView HeightRequest="0.5"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />
                        <Picker ItemsSource="{Binding MonthlyRuleItems}"
                                SelectedIndex="{Binding MonthlyRuleIndex}"
                                FontSize="13"
                                MinimumHeightRequest="44"
                                TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />

                        <!-- Day of month -->
                        <Grid IsVisible="{Binding IsMonthlyDayOfMonth}"
                              ColumnDefinitions="Auto,*" MinimumHeightRequest="44">
                            <Label Grid.Column="0" Text="{x:Static res:AppResources.DayLabel}"
                                   FontSize="13" WidthRequest="56"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                   VerticalOptions="Center" />
                            <Entry Grid.Column="1"
                                   Text="{Binding DayOfMonth}"
                                   Keyboard="Numeric"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                        </Grid>

                        <!-- Nth weekday -->
                        <Grid IsVisible="{Binding IsMonthlyNthWeekday}"
                              ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Picker Grid.Column="0"
                                    ItemsSource="{Binding WeekIndexItems}"
                                    SelectedIndex="{Binding WeekIndexPickerIndex}"
                                    FontSize="13"
                                    MinimumHeightRequest="44"
                                    TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                            <Picker Grid.Column="1"
                                    ItemsSource="{Binding WeekdayItems}"
                                    SelectedIndex="{Binding MonthlyWeekdayIndex}"
                                    FontSize="13"
                                    MinimumHeightRequest="44"
                                    TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- ── Yearly section ── -->
                    <VerticalStackLayout IsVisible="{Binding IsYearly}" Spacing="0">
                        <BoxView HeightRequest="0.5"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />
                        <Picker ItemsSource="{Binding YearlyRuleItems}"
                                SelectedIndex="{Binding YearlyRuleIndex}"
                                FontSize="13"
                                MinimumHeightRequest="44"
                                TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />

                        <!-- Month + Day of month -->
                        <Grid IsVisible="{Binding IsYearlyDayOfMonth}"
                              ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Entry Grid.Column="0"
                                   Text="{Binding YearlyMonth}"
                                   Placeholder="{x:Static res:AppResources.MonthLabel}"
                                   Keyboard="Numeric"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                            <Entry Grid.Column="1"
                                   Text="{Binding YearlyDay}"
                                   Placeholder="{x:Static res:AppResources.DayLabel}"
                                   Keyboard="Numeric"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                        </Grid>

                        <!-- Month + Nth weekday -->
                        <Grid IsVisible="{Binding IsYearlyNthWeekday}"
                              ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Entry Grid.Column="0"
                                   Text="{Binding YearlyMonth}"
                                   Placeholder="{x:Static res:AppResources.MonthLabel}"
                                   Keyboard="Numeric"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                            <Picker Grid.Column="1"
                                    ItemsSource="{Binding WeekIndexItems}"
                                    SelectedIndex="{Binding YearlyWeekIndexPickerIndex}"
                                    FontSize="13"
                                    MinimumHeightRequest="44"
                                    TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                            <Picker Grid.Column="2"
                                    ItemsSource="{Binding WeekdayItems}"
                                    SelectedIndex="{Binding YearlyWeekdayIndex}"
                                    FontSize="13"
                                    MinimumHeightRequest="44"
                                    TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- ── Interval + End Date (shared for all recurrences) ── -->
                    <VerticalStackLayout IsVisible="{Binding IsRecurring}" Spacing="0">
                        <BoxView HeightRequest="0.5"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />
                        <Grid ColumnDefinitions="Auto,*,Auto" MinimumHeightRequest="44">
                            <Label Grid.Column="0" Text="{x:Static res:AppResources.IntervalLabel}"
                                   FontSize="13" WidthRequest="64"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                   VerticalOptions="Center" />
                            <Entry Grid.Column="1"
                                   Text="{Binding Interval}"
                                   Keyboard="Numeric"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                            <Label Grid.Column="2" Text="{Binding IntervalUnitLabel}"
                                   FontSize="13" Margin="8,0,0,0"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                   VerticalOptions="Center" />
                        </Grid>
                        <BoxView HeightRequest="0.5"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />
                        <Grid ColumnDefinitions="Auto,*" MinimumHeightRequest="44">
                            <Label Grid.Column="0" Text="{x:Static res:AppResources.EndDateLabel}"
                                   FontSize="13" WidthRequest="64"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                   VerticalOptions="Center" />
                            <DatePicker Grid.Column="1"
                                        Date="{Binding EndDate}"
                                        FontSize="14"
                                        MinimumHeightRequest="44"
                                        TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                        </Grid>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- ── Holiday Adjustment (shown only for recurring events) ── -->
            <VerticalStackLayout IsVisible="{Binding IsRecurring}" Spacing="0">
                <Label Text="{x:Static res:AppResources.AdjustmentLabel}"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                       Margin="4,12,0,4" />

                <Border BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 8"
                        Padding="12,4"
                        Margin="0,0,0,4">
                    <VerticalStackLayout Spacing="0">

                        <Picker ItemsSource="{Binding AdjustmentItems}"
                                SelectedIndex="{Binding AdjustmentIndex}"
                                FontSize="14"
                                MinimumHeightRequest="48"
                                TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />

                        <!-- Calendar picker (shown when adjustment active) -->
                        <VerticalStackLayout IsVisible="{Binding HasAdjustment}" Spacing="0">
                            <BoxView HeightRequest="0.5"
                                     BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />
                            <Grid ColumnDefinitions="Auto,*" MinimumHeightRequest="48"
                                  IsVisible="{Binding HasAvailableCalendars}">
                                <Label Grid.Column="0" Text="{x:Static res:AppResources.BusinessCalendarLabel}"
                                       FontSize="13" WidthRequest="80"
                                       TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                       VerticalOptions="Center" />
                                <Picker Grid.Column="1"
                                        ItemsSource="{Binding AvailableCalendarNames}"
                                        SelectedIndex="{Binding SelectedCalendarIndex}"
                                        FontSize="14"
                                        MinimumHeightRequest="48"
                                        TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                            </Grid>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- ── Alarm ── -->
            <Label Text="{x:Static res:AppResources.AlarmLabel}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                   Margin="4,12,0,4" />

            <Border BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    Padding="12,4"
                    Margin="0,0,0,16">
                <VerticalStackLayout Spacing="0">

                    <!-- Enable alarm toggle -->
                    <Grid ColumnDefinitions="*,Auto" MinimumHeightRequest="48">
                        <Label Grid.Column="0" Text="{x:Static res:AppResources.AlarmEnable}"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}"
                               VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding AlarmEnabled}" OnColor="{StaticResource GCalBlue}" />
                    </Grid>

                    <!-- Notify options (visible when alarm enabled) -->
                    <VerticalStackLayout IsVisible="{Binding ShowAlarmNotifyOptions}" Spacing="0">

                        <BoxView HeightRequest="0.5"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />
                        <Grid ColumnDefinitions="*,Auto" MinimumHeightRequest="44">
                            <Label Grid.Column="0" Text="{x:Static res:AppResources.AlarmNotify15Min}"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}"
                                   VerticalOptions="Center" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding AlarmNotify15Min}" Color="{StaticResource GCalBlue}" />
                        </Grid>

                        <BoxView HeightRequest="0.5"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />
                        <Grid ColumnDefinitions="*,Auto" MinimumHeightRequest="44">
                            <Label Grid.Column="0" Text="{x:Static res:AppResources.AlarmNotify5Min}"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}"
                                   VerticalOptions="Center" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding AlarmNotify5Min}" Color="{StaticResource GCalBlue}" />
                        </Grid>

                        <BoxView HeightRequest="0.5"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />
                        <Grid ColumnDefinitions="*,Auto" MinimumHeightRequest="44">
                            <Label Grid.Column="0" Text="{x:Static res:AppResources.AlarmNotify1Min}"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}"
                                   VerticalOptions="Center" />
                            <CheckBox Grid.Column="1" IsChecked="{Binding AlarmNotify1Min}" Color="{StaticResource GCalBlue}" />
                        </Grid>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- ── Save / Cancel ── -->
            <Grid ColumnDefinitions="*,56" ColumnSpacing="8" Margin="0,20,0,32">
                <Button Grid.Column="0"
                        Text="{x:Static res:AppResources.SaveButton}"
                        Clicked="OnSaveClicked"
                        BackgroundColor="{StaticResource GCalBlue}"
                        TextColor="{StaticResource White}"
                        FontSize="15"
                        CornerRadius="8"
                        HeightRequest="48" />
                <Button Grid.Column="1"
                        Text="✕"
                        Clicked="OnCancelClicked"
                        BackgroundColor="Transparent"
                        BorderColor="{StaticResource GCalBorder}"
                        BorderWidth="1"
                        TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                        FontSize="18"
                        CornerRadius="8"
                        HeightRequest="48" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
