<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NolumiaScheduler.Presentation.ViewModels"
             xmlns:res="clr-namespace:NolumiaScheduler.Resources.Strings"
             x:Class="NolumiaScheduler.Presentation.Pages.BusinessCalendarEditPage"
             x:DataType="vm:BusinessCalendarEditViewModel"
             Title="{Binding PageTitle}">

    <ScrollView BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurfaceVariant}, Dark={StaticResource GCalSurfaceVariantDark}}">
        <VerticalStackLayout Padding="16" Spacing="0">

            <!-- ── Calendar Name ── -->
            <Label Text="{x:Static res:AppResources.CalendarNamePlaceholder}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                   Margin="4,16,0,4" />

            <Border BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    Padding="12,0">
                <Entry Text="{Binding Name}"
                       Placeholder="{x:Static res:AppResources.CalendarNamePlaceholder}"
                       FontSize="15"
                       MinimumHeightRequest="48"
                       TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
            </Border>

            <!-- ── Working Days ── -->
            <Label Text="{x:Static res:AppResources.WorkdaysLabel}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                   Margin="4,20,0,8" />

            <Border BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8"
                    Padding="12,8">
                <Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="4">
                    <!-- Sun -->
                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                        <Label Text="{x:Static res:AppResources.DaySun}" FontSize="11"
                               TextColor="{StaticResource GCalRed}" HorizontalOptions="Center" />
                        <CheckBox IsChecked="{Binding WorkSunday}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <!-- Mon -->
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                        <Label Text="{x:Static res:AppResources.DayMon}" FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                               HorizontalOptions="Center" />
                        <CheckBox IsChecked="{Binding WorkMonday}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <!-- Tue -->
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                        <Label Text="{x:Static res:AppResources.DayTue}" FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                               HorizontalOptions="Center" />
                        <CheckBox IsChecked="{Binding WorkTuesday}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <!-- Wed -->
                    <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                        <Label Text="{x:Static res:AppResources.DayWed}" FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                               HorizontalOptions="Center" />
                        <CheckBox IsChecked="{Binding WorkWednesday}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <!-- Thu -->
                    <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="4">
                        <Label Text="{x:Static res:AppResources.DayThu}" FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                               HorizontalOptions="Center" />
                        <CheckBox IsChecked="{Binding WorkThursday}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <!-- Fri -->
                    <VerticalStackLayout Grid.Column="5" HorizontalOptions="Center" Spacing="4">
                        <Label Text="{x:Static res:AppResources.DayFri}" FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                               HorizontalOptions="Center" />
                        <CheckBox IsChecked="{Binding WorkFriday}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <!-- Sat -->
                    <VerticalStackLayout Grid.Column="6" HorizontalOptions="Center" Spacing="4">
                        <Label Text="{x:Static res:AppResources.DaySat}" FontSize="11"
                               TextColor="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                        <CheckBox IsChecked="{Binding WorkSaturday}" Color="{StaticResource GCalBlue}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- ── Holidays ── -->
            <Label Text="{x:Static res:AppResources.HolidaysLabel}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                   Margin="4,20,0,8" />

            <!-- Holiday list -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 8">
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Holidays}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:HolidayDisplayItem">
                            <Grid Padding="12,0"
                                  MinimumHeightRequest="48"
                                  ColumnDefinitions="*,40">
                                <Label Grid.Column="0"
                                       Text="{Binding DisplayText}"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="×"
                                        Command="{Binding RemoveCommand}"
                                        BackgroundColor="Transparent"
                                        BorderWidth="0"
                                        TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                        FontSize="16"
                                        Padding="0"
                                        WidthRequest="40"
                                        HeightRequest="40" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                    <!-- Add holiday row -->
                    <Grid Padding="12,8" ColumnDefinitions="*,*,56" ColumnSpacing="8"
                          BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurfaceVariant}, Dark={StaticResource GCalSurfaceVariantDark}}">
                        <DatePicker Grid.Column="0"
                                    Date="{Binding NewHolidayDate}"
                                    FontSize="13"
                                    MinimumHeightRequest="40"
                                    TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                        <Entry Grid.Column="1"
                               Text="{Binding NewHolidayName}"
                               Placeholder="{x:Static res:AppResources.HolidayNamePlaceholder}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                        <Button Grid.Column="2"
                                Text="{x:Static res:AppResources.AddHolidayButton}"
                                Command="{Binding AddHolidayCommand}"
                                BackgroundColor="{StaticResource GCalBlue}"
                                TextColor="{StaticResource White}"
                                FontSize="13"
                                Padding="4,0"
                                CornerRadius="6"
                                HeightRequest="40" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ── Save Button ── -->
            <Button Text="{x:Static res:AppResources.SaveButton}"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource GCalBlue}"
                    TextColor="{StaticResource White}"
                    FontSize="15"
                    CornerRadius="8"
                    HeightRequest="48"
                    Margin="0,24,0,0" />

            <!-- ── Delete Button (editing only) ── -->
            <Button Text="{x:Static res:AppResources.DeleteCalendarButton}"
                    Command="{Binding DeleteCommand}"
                    IsVisible="{Binding IsEditing}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}"
                    TextColor="{StaticResource GCalRed}"
                    BorderColor="{StaticResource GCalRed}"
                    BorderWidth="1"
                    FontSize="15"
                    CornerRadius="8"
                    HeightRequest="48"
                    Margin="0,12,0,24" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
