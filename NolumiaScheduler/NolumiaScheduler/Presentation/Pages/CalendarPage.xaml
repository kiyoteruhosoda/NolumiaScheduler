<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NolumiaScheduler.Presentation.ViewModels"
             xmlns:res="clr-namespace:NolumiaScheduler.Resources.Strings"
             xmlns:controls="clr-namespace:NolumiaScheduler.Presentation.Controls"
             x:Class="NolumiaScheduler.Presentation.Pages.CalendarPage"
             x:DataType="vm:CalendarViewModel"
             Title="{x:Static res:AppResources.CalendarTitle}">

    <ContentPage.Resources>
        <!-- Bootstrap-style outlined button: border + label inside a Border -->
        <Style x:Key="OutlineButtonStyle" TargetType="Border">
            <Setter Property="StrokeShape" Value="RoundRectangle 6" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HeightRequest" Value="32" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>

        <!-- Small icon button (edit/delete) -->
        <Style x:Key="IconBorderStyle" TargetType="Border">
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="StrokeShape" Value="RoundRectangle 20" />
            <Setter Property="WidthRequest" Value="40" />
            <Setter Property="HeightRequest" Value="40" />
            <Setter Property="HorizontalOptions" Value="Center" />
            <Setter Property="VerticalOptions" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>

    </ContentPage.Resources>

    <!--
        Row layout:
          0  Header (48)
          1  Separator (1)
          2  Day-of-week labels (36)
          3  Separator (1)
          4  6×7 calendar grid (*)
          5  Selected-day events panel (Auto)
    -->
    <Grid RowDefinitions="48,40,1,36,1,*,Auto">

        <!-- ── Header ── -->
        <Grid Grid.Row="0"
              ColumnDefinitions="48,*,Auto,Auto,48"
              BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}">

            <!-- ‹ Prev month -->
            <Border x:Name="BtnPrev"
                    Grid.Column="0"
                    Style="{StaticResource IconBorderStyle}"
                    WidthRequest="36" HeightRequest="36">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding PreviousMonthCommand}" />
                    <PointerGestureRecognizer PointerEntered="OnHeaderButtonEntered" PointerExited="OnHeaderButtonExited" />
                </Border.GestureRecognizers>
                <Label Text="&#x2039;"
                       FontSize="26"
                       TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource GCalTextSecondaryDark}}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <Label Grid.Column="1"
                   Text="{Binding MonthYearTitle}"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />

            <!-- Today button (Bootstrap outlined) -->
            <Border x:Name="BtnToday"
                    Grid.Column="2"
                    Style="{StaticResource OutlineButtonStyle}"
                    Margin="4,0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoTodayCommand}" />
                    <PointerGestureRecognizer PointerEntered="OnOutlineButtonEntered" PointerExited="OnOutlineButtonExited" />
                </Border.GestureRecognizers>
                <Label Text="{x:Static res:AppResources.TodayButton}"
                       FontSize="13"
                       TextColor="{StaticResource GCalBlue}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <!-- + New Event button (Bootstrap outlined) -->
            <Border x:Name="BtnNewEvent"
                    Grid.Column="3"
                    Style="{StaticResource OutlineButtonStyle}"
                    Margin="4,0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewEventClicked" />
                    <PointerGestureRecognizer PointerEntered="OnOutlineButtonEntered" PointerExited="OnOutlineButtonExited" />
                </Border.GestureRecognizers>
                <Label Text="+"
                       FontSize="20"
                       TextColor="{StaticResource GCalBlue}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <!-- › Next month -->
            <Border x:Name="BtnNext"
                    Grid.Column="4"
                    Style="{StaticResource IconBorderStyle}"
                    WidthRequest="36" HeightRequest="36">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NextMonthCommand}" />
                    <PointerGestureRecognizer PointerEntered="OnHeaderButtonEntered" PointerExited="OnHeaderButtonExited" />
                </Border.GestureRecognizers>
                <Label Text="&#x203A;"
                       FontSize="26"
                       TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource GCalTextSecondaryDark}}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>


        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8" Padding="12,4" BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}">
            <Border Grid.Column="0" Style="{StaticResource OutlineButtonStyle}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SwitchToMonthViewCommand}" />
                    <PointerGestureRecognizer PointerEntered="OnOutlineButtonEntered" PointerExited="OnOutlineButtonExited" />
                </Border.GestureRecognizers>
                <Label Text="{x:Static res:AppResources.MonthViewLabel}" FontSize="13" TextColor="{StaticResource GCalBlue}" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <Border Grid.Column="1" Style="{StaticResource OutlineButtonStyle}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SwitchToWeekViewCommand}" />
                    <PointerGestureRecognizer PointerEntered="OnOutlineButtonEntered" PointerExited="OnOutlineButtonExited" />
                </Border.GestureRecognizers>
                <Label Text="{x:Static res:AppResources.WeekViewLabel}" FontSize="13" TextColor="{StaticResource GCalBlue}" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>

        <!-- ── Separator: header / day-of-week ── -->
        <BoxView Grid.Row="2"
                 BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />

        <!-- ── Day-of-week labels ── -->
        <Grid Grid.Row="3"
              IsVisible="{Binding IsMonthMode}"
              ColumnDefinitions="*,*,*,*,*,*,*"
              BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}">

            <Label Grid.Column="0"
                   Text="{x:Static res:AppResources.DaySun}" FontSize="11"
                   TextColor="{StaticResource GCalRed}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <Label Grid.Column="1"
                   Text="{x:Static res:AppResources.DayMon}" FontSize="11"
                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <Label Grid.Column="2"
                   Text="{x:Static res:AppResources.DayTue}" FontSize="11"
                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <Label Grid.Column="3"
                   Text="{x:Static res:AppResources.DayWed}" FontSize="11"
                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <Label Grid.Column="4"
                   Text="{x:Static res:AppResources.DayThu}" FontSize="11"
                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <Label Grid.Column="5"
                   Text="{x:Static res:AppResources.DayFri}" FontSize="11"
                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <Label Grid.Column="6"
                   Text="{x:Static res:AppResources.DaySat}" FontSize="11"
                   TextColor="{StaticResource GCalBlue}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>

        <!-- ── Separator: day-of-week / calendar grid ── -->
        <BoxView Grid.Row="4" IsVisible="{Binding IsMonthMode}"
                 BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />

        <!-- ── 6×7 calendar grid ── -->
        <CollectionView Grid.Row="5" IsVisible="{Binding IsMonthMode}"
                        x:Name="DayCellsView"
                        ItemsSource="{Binding DayCells}"
                        SelectionMode="Single"
                        SelectionChanged="OnDayCellSelected"
                        BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}">

            <!-- Swipe left/right to navigate months -->
            <CollectionView.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Left"  Command="{Binding NextMonthCommand}" />
                <SwipeGestureRecognizer Direction="Right" Command="{Binding PreviousMonthCommand}" />
            </CollectionView.GestureRecognizers>

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="7" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:CalendarDayCell">
                    <Grid HeightRequest="88" Padding="2,2,2,0"
                          BackgroundColor="{Binding CellBackgroundColor}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="18" />
                        </Grid.RowDefinitions>

                        <!-- Day number with today/selected circle -->
                        <Grid Grid.Row="0"
                              WidthRequest="30"
                              HeightRequest="30"
                              HorizontalOptions="Center"
                              VerticalOptions="Center">
                            <BoxView CornerRadius="15"
                                     BackgroundColor="{Binding CircleColor}"
                                     HorizontalOptions="Fill"
                                     VerticalOptions="Fill" />
                            <Label Text="{Binding DayLabel}"
                                   TextColor="{Binding DayTextColor}"
                                   FontSize="13"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Holiday name (shown in red when set) -->
                        <Label Grid.Row="1"
                               IsVisible="{Binding IsHoliday}"
                               Text="{Binding HolidayName}"
                               TextColor="{AppThemeBinding Light={StaticResource GCalRed}, Dark={StaticResource GCalRedDark}}"
                               FontSize="7"
                               MaxLines="1"
                               LineBreakMode="TailTruncation"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               Margin="1,0" />

                        <!-- First event chip -->
                        <Border Grid.Row="2"
                                IsVisible="{Binding HasFirstEvent}"
                                BackgroundColor="{Binding FirstEventColor}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 3"
                                Padding="3,1"
                                Margin="2,1,2,0">
                            <Label Text="{Binding FirstEventTitle}"
                                   TextColor="White"
                                   FontSize="9"
                                   MaxLines="1"
                                   LineBreakMode="TailTruncation" />
                        </Border>

                        <!-- Second event chip (only when no overflow) -->
                        <Border Grid.Row="3"
                                IsVisible="{Binding ShowSecondChip}"
                                BackgroundColor="{Binding SecondEventColor}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 3"
                                Padding="3,1"
                                Margin="2,1,2,0">
                            <Label Text="{Binding SecondEventTitle}"
                                   TextColor="White"
                                   FontSize="9"
                                   MaxLines="1"
                                   LineBreakMode="TailTruncation" />
                        </Border>

                        <!-- +N overflow label -->
                        <Label Grid.Row="3"
                               IsVisible="{Binding HasMoreEvents}"
                               Text="{Binding MoreText}"
                               TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                               FontSize="9"
                               Margin="4,2,2,0" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>


        <controls:WeekCalendarView Grid.Row="5" IsVisible="{Binding IsWeekMode}"
                                  WeekTimeSlots="{Binding WeekTimeSlots}"
                                  WeekDayColumns="{Binding WeekDayColumns}"
                                  WeekAllDayEventBlocks="{Binding WeekAllDayEventBlocks}"
                                  WeekAllDayLaneHeight="{Binding WeekAllDayLaneHeight}"
                                  WeekCanvasHeight="{Binding WeekCanvasHeight}"
                                  WeekDayColumnWidth="{Binding WeekDayColumnWidth}"
                                  WeekStartDate="{Binding WeekStartDate}"
                                  IsCurrentWeek="{Binding IsCurrentWeek}"
                                  CurrentTimeLineTop="{Binding CurrentTimeLineTop}"
                                  EmptySlotTapped="OnWeekEmptySlotTapped"
                                  EventBlockTapped="OnWeekEventBlockTapped"
                                  EventDragCompleted="OnWeekEventDragCompleted"
                                  EventResizeCompleted="OnWeekEventResizeCompleted" />

        <!-- ── Selected-day events panel ── -->
        <Grid Grid.Row="6"
              IsVisible="{Binding HasSelectedDay}"
              RowDefinitions="1,44,Auto,Auto,Auto"
              BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurfaceVariant}, Dark={StaticResource GCalSurfaceVariantDark}}">

            <!-- Top divider -->
            <BoxView Grid.Row="0"
                     BackgroundColor="{AppThemeBinding Light={StaticResource GCalBorder}, Dark={StaticResource GCalBorderDark}}" />

            <!-- Selected day label -->
            <Label Grid.Row="1"
                   Text="{Binding SelectedDayLabel}"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}"
                   VerticalOptions="Center"
                   Margin="16,0" />

            <!-- Holiday banner (shown when selected day is a holiday) -->
            <Border Grid.Row="2"
                    IsVisible="{Binding SelectedDayIsHoliday}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource GCalHolidayBg}, Dark={StaticResource GCalHolidayBgDark}}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 6"
                    Padding="12,6"
                    Margin="16,4,16,0">
                <Label Text="{Binding SelectedDayHolidayText}"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource GCalRed}, Dark={StaticResource GCalRedDark}}" />
            </Border>

            <!-- Empty state when no events for the selected day -->
            <Label Grid.Row="3"
                   IsVisible="{Binding SelectedDayHasNoEvents}"
                   Text="{x:Static res:AppResources.NoEventsLabel}"
                   FontSize="13"
                   TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                   HorizontalOptions="Center"
                   Margin="16,8,16,16" />

            <!-- Event list (scrollable, capped at ~200dp) -->
            <ScrollView Grid.Row="4" MaximumHeightRequest="200">
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectedDayEvents}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:CalendarEventItem">
                            <Border x:Name="EventItemBorder"
                                    Padding="0"
                                    BackgroundColor="Transparent"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 0">
                                <Grid Padding="16,6,12,6"
                                      MinimumHeightRequest="48"
                                      ColumnDefinitions="14,*,44,48"
                                      ColumnSpacing="4">
                                    <Grid.GestureRecognizers>
                                        <PointerGestureRecognizer
                                            PointerEntered="OnEventItemPointerEntered"
                                            PointerExited="OnEventItemPointerExited" />
                                    </Grid.GestureRecognizers>

                                <!-- Colored dot -->
                                <BoxView Grid.Column="0"
                                         WidthRequest="10"
                                         HeightRequest="10"
                                         CornerRadius="5"
                                         BackgroundColor="{Binding DotColor}"
                                         VerticalOptions="Start"
                                         Margin="0,5,0,0" />

                                <!-- Event details -->
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="{Binding Title}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource GCalTextPrimary}, Dark={StaticResource White}}" />
                                    <Label Text="{Binding TimeRange}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}" />
                                    <Label Text="{Binding Location}"
                                           FontSize="12"
                                           IsVisible="{Binding HasLocation}"
                                           TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}" />
                                    <Border IsVisible="{Binding HasBadge}"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource GCalBlueLight}, Dark={StaticResource GCalBlueLightDark}}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 4"
                                            Padding="6,2"
                                            HorizontalOptions="Start">
                                        <Label Text="{Binding BadgeText}"
                                               FontSize="11"
                                               TextColor="{AppThemeBinding Light={StaticResource GCalBlue}, Dark={StaticResource GCalBlueDark}}" />
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Edit button -->
                                <Border Grid.Column="2"
                                        Style="{StaticResource IconBorderStyle}"
                                        Margin="2,0">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnEditEventClicked" />
                                        <PointerGestureRecognizer
                                            PointerEntered="OnIconBorderEntered"
                                            PointerExited="OnIconBorderExited" />
                                    </Border.GestureRecognizers>
                                    <Label Text="✏"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <!-- Delete button -->
                                <Border Grid.Column="3"
                                        Style="{StaticResource IconBorderStyle}"
                                        Margin="2,0,6,0">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDeleteEventClicked" />
                                        <PointerGestureRecognizer
                                            PointerEntered="OnIconBorderEntered"
                                            PointerExited="OnIconBorderExited" />
                                    </Border.GestureRecognizers>
                                    <Label Text="🗑"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light={StaticResource GCalTextSecondary}, Dark={StaticResource GCalTextSecondaryDark}}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

    </Grid>
</ContentPage>
