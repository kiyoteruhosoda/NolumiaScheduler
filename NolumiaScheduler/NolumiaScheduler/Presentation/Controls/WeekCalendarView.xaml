<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NolumiaScheduler.Presentation.ViewModels"
             xmlns:controls="clr-namespace:NolumiaScheduler.Presentation.Controls"
             x:Class="NolumiaScheduler.Presentation.Controls.WeekCalendarView"
             x:Name="Root">
    <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="56,*"
          BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}">

        <Grid x:Name="WeekHeaderGrid" Grid.Row="0" Grid.Column="1" ColumnSpacing="1" Padding="0,2,0,6"/>

        <Label Grid.Row="1" Grid.Column="0" Text="終日" FontSize="10" VerticalTextAlignment="Center" Margin="2,0"/>
        <AbsoluteLayout Grid.Row="1" Grid.Column="1" HeightRequest="{Binding Source={x:Reference Root}, Path=WeekAllDayLaneHeight}" BackgroundColor="{AppThemeBinding Light=#FAFBFD,Dark=#232323}">
            <AbsoluteLayout x:Name="WeekAllDayEventsLayer" BindableLayout.ItemsSource="{Binding Source={x:Reference Root}, Path=WeekAllDayEventBlocks}"/>
        </AbsoluteLayout>

        <ScrollView x:Name="WeekScroll" Grid.Row="2" Grid.ColumnSpan="2" Orientation="Vertical" Scrolled="OnWeekScrollScrolled">
            <Grid ColumnDefinitions="56,*" HeightRequest="{Binding Source={x:Reference Root}, Path=WeekCanvasHeight}">
                <VerticalStackLayout Grid.Column="0" BindableLayout.ItemsSource="{Binding Source={x:Reference Root}, Path=WeekTimeSlots}" Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:WeekTimeSlot">
                            <Label Text="{Binding HourLabel}" FontSize="10" HeightRequest="60" VerticalTextAlignment="Start" Margin="2,0"/>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
                <Grid x:Name="WeekBodyGrid" Grid.Column="1" ColumnSpacing="1"/>
            </Grid>
        </ScrollView>
    </Grid>
</ContentView>
