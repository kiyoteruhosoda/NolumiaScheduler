<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NolumiaScheduler.Presentation.ViewModels"
             xmlns:controls="clr-namespace:NolumiaScheduler.Presentation.Controls"
             x:Class="NolumiaScheduler.Presentation.Controls.WeekCalendarView"
             x:Name="Root">
    <ScrollView x:Name="WeekScroll" Orientation="Both">
        <Grid RowDefinitions="Auto,*" ColumnDefinitions="56,*"
              BackgroundColor="{AppThemeBinding Light={StaticResource GCalSurface}, Dark={StaticResource GCalSurfaceDark}}">
            <CollectionView Grid.Row="1" Grid.Column="0" ItemsSource="{Binding Source={x:Reference Root}, Path=WeekTimeSlots}" SelectionMode="None" HeightRequest="{Binding Source={x:Reference Root}, Path=WeekCanvasHeight}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:WeekTimeSlot">
                        <Label Text="{Binding HourLabel}" FontSize="10" HeightRequest="60" VerticalTextAlignment="Start" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <CollectionView Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" ItemsSource="{Binding Source={x:Reference Root}, Path=WeekDayColumns}" SelectionMode="None" HorizontalScrollBarVisibility="Never" HeightRequest="{Binding Source={x:Reference Root}, Path=WeekCanvasHeight}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="2" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:WeekDayColumn">
                        <Grid RowDefinitions="Auto,*" Margin="1,0" WidthRequest="{Binding Source={x:Reference Root}, Path=WeekDayColumnWidth}">
                            <Label Grid.Row="0" Text="{Binding Header}" FontSize="11" HorizontalOptions="Center" Margin="0,2" FontAttributes="{Binding HeaderFontAttributes}" TextColor="{Binding HeaderTextColor}" />
                            <AbsoluteLayout Grid.Row="1" HeightRequest="{Binding Source={x:Reference Root}, Path=WeekCanvasHeight}" BackgroundColor="{Binding DayBackgroundColor}">
                                <AbsoluteLayout.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnEmptySlotTapped" />
                                </AbsoluteLayout.GestureRecognizers>
                                <controls:WeekGridBackgroundView IsToday="{Binding IsToday}" IsCurrentWeek="{Binding Source={x:Reference Root}, Path=IsCurrentWeek}" CurrentTimeLineTop="{Binding Source={x:Reference Root}, Path=CurrentTimeLineTop}" HeightRequest="{Binding Source={x:Reference Root}, Path=WeekCanvasHeight}" />
                                <AbsoluteLayout BindableLayout.ItemsSource="{Binding GuideLines}" InputTransparent="True" IsVisible="False">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="vm:IWeekGuideLine">
                                            <BoxView HeightRequest="1"
                                                     Color="{AppThemeBinding Light=#D0D7DE, Dark=#3A3A3A}"
                                                     AbsoluteLayout.LayoutBounds="0,{Binding Top},1,1"
                                                     AbsoluteLayout.LayoutFlags="WidthProportional">
                                                <BoxView.Triggers>
                                                    <DataTrigger TargetType="BoxView" Binding="{Binding IsPrimary}" Value="False">
                                                        <Setter Property="Opacity" Value="0.35" />
                                                    </DataTrigger>
                                                </BoxView.Triggers>
                                            </BoxView>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </AbsoluteLayout>
                                <AbsoluteLayout BindableLayout.ItemsSource="{Binding EventBlocks}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="vm:WeekEventBlock">
                                            <Border Padding="6,4" BackgroundColor="{Binding BackgroundColor}" StrokeThickness="1" Stroke="Transparent" StrokeShape="RoundRectangle 6" MinimumHeightRequest="44"
                                                    AbsoluteLayout.LayoutBounds="{Binding LeftRatio}, {Binding Top}, {Binding WidthRatio}, {Binding Height}"
                                                    AbsoluteLayout.LayoutFlags="XProportional,WidthProportional">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Stroke" Value="#0B57D0" />
                                                        <Setter Property="StrokeThickness" Value="2" />
                                                        <Setter Property="ZIndex" Value="10" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnEventBlockTapped" />
                                                </Border.GestureRecognizers>
                                                <VerticalStackLayout Spacing="0">
                                                    <Label Text="{Binding TimeLabel}" FontSize="9" TextColor="White" />
                                                    <Label Text="{Binding Title}" FontSize="10" TextColor="White" LineBreakMode="TailTruncation" />
                                                </VerticalStackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </AbsoluteLayout>
                                
                            </AbsoluteLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </ScrollView>
</ContentView>
