<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="NolumiaScheduler.Presentation.Pages.CalendarPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:NolumiaScheduler.Presentation.ViewModels"
      xmlns:controls="using:NolumiaScheduler.Presentation.Controls"
      xmlns:helpers="using:NolumiaScheduler.WinUI.Helpers"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <helpers:ColorToBrushConverter x:Key="ColorToBrush"/>
        <helpers:NullToCollapsedConverter x:Key="NullToCollapsed"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisible"/>
    </Page.Resources>

    <!--
        Row layout:
          0  Header (48)
          1  View-mode bar (40)
          2  Separator (1)
          3  Day-of-week labels (36)
          4  Separator (1)
          5  6x7 calendar grid OR week view (*)
          6  Selected-day events panel (Auto)
    -->
    <Grid RowDefinitions="48,40,1,36,1,*,Auto"
          Background="{ThemeResource GCalSurface}">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="48,*,Auto,Auto,48"
              Background="{ThemeResource GCalSurface}">

            <Button x:Name="BtnPrev" Grid.Column="0" Content="&#x2039;" FontSize="26"
                    Width="36" Height="36" Padding="0" CornerRadius="18"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{ThemeResource GCalTextPrimary}"
                    Click="OnPrevClicked"/>

            <TextBlock x:Name="MonthYearLabel" Grid.Column="1" FontSize="18" FontWeight="SemiBold"
                       Foreground="{ThemeResource GCalTextPrimary}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <Button x:Name="BtnToday" Grid.Column="2" FontSize="13" Height="32"
                    Padding="10,0" Margin="4,0" CornerRadius="6"
                    Background="Transparent" BorderThickness="1"
                    BorderBrush="{ThemeResource GCalBorder}"
                    Foreground="{StaticResource GCalBlue}"
                    VerticalAlignment="Center"
                    Click="OnTodayClicked"/>

            <Button x:Name="BtnNewEvent" Grid.Column="3" Content="+" FontSize="20"
                    Height="32" Width="40" Padding="0" Margin="4,0" CornerRadius="6"
                    Background="Transparent" BorderThickness="1"
                    BorderBrush="{ThemeResource GCalBorder}"
                    Foreground="{StaticResource GCalBlue}"
                    VerticalAlignment="Center"
                    Click="OnNewEventClicked"/>

            <Button x:Name="BtnNext" Grid.Column="4" Content="&#x203A;" FontSize="26"
                    Width="36" Height="36" Padding="0" CornerRadius="18"
                    Background="Transparent" BorderThickness="0"
                    Foreground="{ThemeResource GCalTextPrimary}"
                    Click="OnNextClicked"/>
        </Grid>

        <!-- View mode bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Padding="12,4"
                    Background="{ThemeResource GCalSurface}">
            <Button x:Name="BtnMonthView" Height="32" Padding="10,0" CornerRadius="6"
                    Background="Transparent" BorderThickness="1"
                    BorderBrush="{ThemeResource GCalBorder}"
                    Foreground="{StaticResource GCalBlue}"
                    Click="OnMonthViewClicked"/>
            <Button x:Name="BtnWeekView" Height="32" Padding="10,0" CornerRadius="6"
                    Background="Transparent" BorderThickness="1"
                    BorderBrush="{ThemeResource GCalBorder}"
                    Foreground="{StaticResource GCalBlue}"
                    Click="OnWeekViewClicked"/>
        </StackPanel>

        <!-- Separator -->
        <Rectangle Grid.Row="2" Fill="{ThemeResource GCalBorder}"/>

        <!-- Day-of-week labels (month mode only) -->
        <Grid x:Name="DayOfWeekHeader" Grid.Row="3"
              ColumnDefinitions="*,*,*,*,*,*,*"
              Background="{ThemeResource GCalSurface}">
            <TextBlock x:Name="LblSun" Grid.Column="0" FontSize="11"
                       Foreground="{StaticResource GCalRed}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="LblMon" Grid.Column="1" FontSize="11"
                       Foreground="{ThemeResource GCalTextSecondary}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="LblTue" Grid.Column="2" FontSize="11"
                       Foreground="{ThemeResource GCalTextSecondary}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="LblWed" Grid.Column="3" FontSize="11"
                       Foreground="{ThemeResource GCalTextSecondary}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="LblThu" Grid.Column="4" FontSize="11"
                       Foreground="{ThemeResource GCalTextSecondary}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="LblFri" Grid.Column="5" FontSize="11"
                       Foreground="{ThemeResource GCalTextSecondary}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="LblSat" Grid.Column="6" FontSize="11"
                       Foreground="{StaticResource GCalBlue}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- Separator -->
        <Rectangle x:Name="GridSeparator" Grid.Row="4" Fill="{ThemeResource GCalBorder}"/>

        <!-- Month grid (ItemsRepeater 7-column) -->
        <ItemsRepeater x:Name="MonthGrid" Grid.Row="5"
                       Background="{ThemeResource GCalSurface}">
            <ItemsRepeater.Layout>
                <UniformGridLayout MaximumRowsOrColumns="7" Orientation="Horizontal"
                                   ItemsStretch="Fill"/>
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="vm:CalendarDayCell">
                    <Border MinHeight="80"
                            BorderThickness="0,0,0.5,0.5"
                            BorderBrush="{ThemeResource GCalBorder}"
                            Background="{x:Bind CellBackgroundColor, Converter={StaticResource ColorToBrush}, Mode=OneWay}"
                            Tapped="OnDayCellTapped">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" Padding="2">
                            <!-- Circle + day number -->
                            <Grid Grid.Row="0" HorizontalAlignment="Center" Width="28" Height="28" Margin="0,4,0,2">
                                <Ellipse Fill="{x:Bind CircleColor, Converter={StaticResource ColorToBrush}, Mode=OneWay}"/>
                                <TextBlock Text="{x:Bind DayLabel}"
                                           FontSize="13"
                                           Foreground="{x:Bind DayTextColor, Converter={StaticResource ColorToBrush}, Mode=OneWay}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <!-- Event chip 1 -->
                            <Border Grid.Row="1" Height="14" CornerRadius="3"
                                    Margin="1,1" Padding="3,0"
                                    Background="{x:Bind FirstEventColor, Converter={StaticResource ColorToBrush}, Mode=OneWay}"
                                    Visibility="{x:Bind FirstEvent, Converter={StaticResource NullToCollapsed}, Mode=OneWay}">
                                <TextBlock Text="{x:Bind FirstEventTitle, Mode=OneWay}" FontSize="10"
                                           Foreground="White" TextTrimming="CharacterEllipsis"/>
                            </Border>
                            <!-- Event chip 2 -->
                            <Border Grid.Row="2" Height="14" CornerRadius="3"
                                    Margin="1,1" Padding="3,0"
                                    Background="{x:Bind SecondEventColor, Converter={StaticResource ColorToBrush}, Mode=OneWay}"
                                    Visibility="{x:Bind ShowSecondChip, Converter={StaticResource BoolToVisible}, Mode=OneWay}">
                                <TextBlock Text="{x:Bind SecondEventTitle, Mode=OneWay}" FontSize="10"
                                           Foreground="White" TextTrimming="CharacterEllipsis"/>
                            </Border>
                            <!-- "+N more" label -->
                            <TextBlock Grid.Row="3"
                                       Text="{x:Bind MoreText, Mode=OneWay}"
                                       FontSize="10" Margin="3,0"
                                       Foreground="{ThemeResource GCalTextSecondary}"
                                       Visibility="{x:Bind HasMoreEvents, Converter={StaticResource BoolToVisible}, Mode=OneWay}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>

        <!-- Week view -->
        <controls:WeekCalendarView x:Name="WeekView" Grid.Row="5"
                                   Visibility="Collapsed"
                                   EmptySlotTapped="OnWeekEmptySlotTapped"
                                   EventBlockTapped="OnWeekEventBlockTapped"
                                   EventDragCompleted="OnWeekEventDragCompleted"
                                   EventResizeCompleted="OnWeekEventResizeCompleted"/>

        <!-- Selected-day events panel -->
        <Border x:Name="SelectedDayPanel" Grid.Row="6" Visibility="Collapsed"
                BorderThickness="0,1,0,0" BorderBrush="{ThemeResource GCalBorder}"
                Background="{ThemeResource GCalSurface}">
            <StackPanel>
                <!-- Selected day label + close button -->
                <Grid ColumnDefinitions="*,48" Padding="12,8">
                    <TextBlock x:Name="SelectedDayLabel" Grid.Column="0" FontSize="14" FontWeight="SemiBold"
                               Foreground="{ThemeResource GCalTextPrimary}" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="&#x2715;" Width="40" Height="40" FontSize="16"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{ThemeResource GCalTextSecondary}"
                            Click="OnCloseSelectedDay"/>
                </Grid>
                <!-- Events list -->
                <ItemsControl x:Name="EventsList" MaxHeight="200">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CalendarEventItem">
                            <Grid ColumnDefinitions="12,*,Auto,Auto" MinHeight="48" Padding="12,4">
                                <Rectangle Grid.Column="0" Width="4" Height="32" RadiusX="2" RadiusY="2"
                                           Fill="{x:Bind DotColor, Converter={StaticResource ColorToBrush}}"/>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Title}" FontSize="14"
                                               Foreground="{ThemeResource GCalTextPrimary}"/>
                                    <TextBlock Text="{x:Bind TimeRange}" FontSize="12"
                                               Foreground="{ThemeResource GCalTextSecondary}"/>
                                </StackPanel>
                                <Button Grid.Column="2" Content="&#x270E;" Width="40" Height="40"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{ThemeResource GCalTextSecondary}"
                                        Tag="{x:Bind EventId}"
                                        Click="OnEditEventClicked"/>
                                <Button Grid.Column="3" Content="&#x2715;" Width="40" Height="40"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="{ThemeResource GCalTextSecondary}"
                                        Tag="{x:Bind EventId}"
                                        Click="OnDeleteEventClicked"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <!-- No events label -->
                <TextBlock x:Name="NoEventsLabel" Visibility="Collapsed"
                           FontSize="13" Margin="12,8"
                           Foreground="{ThemeResource GCalTextSecondary}"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>
