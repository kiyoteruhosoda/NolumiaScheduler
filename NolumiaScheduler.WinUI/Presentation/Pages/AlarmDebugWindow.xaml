<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NolumiaScheduler.WinUI.Presentation.Pages.AlarmDebugWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="アラームデバッグ">

    <ScrollViewer>
        <StackPanel Padding="16" Spacing="0">

            <!-- ═══ Header: Clock + Buttons ═══ -->
            <TextBlock x:Name="ClockLabel" FontSize="28" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,8" />

            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                <Button Content="更新" Click="OnRefreshClicked" />
                <Button Content="テストアラーム表示" Click="OnTestAlarmClicked" />
                <Button x:Name="CopyButton" Content="クリップボードにコピー" Click="OnCopyClicked" />
                <Button Content="JSONフォルダを開く" Click="OnOpenJsonFolderClicked" />
            </StackPanel>

            <!-- ═══ Section 1: Summary ═══ -->
            <TextBlock Text="■ サマリー" FontSize="14" FontWeight="Bold" Margin="0,0,0,4" />
            <Border Background="{ThemeResource SystemControlBackgroundListLowBrush}"
                    CornerRadius="4" Padding="10" Margin="0,0,0,12">
                <TextBlock x:Name="SummaryLabel" FontSize="11" FontFamily="Consolas"
                           TextWrapping="Wrap" IsTextSelectionEnabled="True" />
            </Border>

            <!-- ═══ Section 2: All Events (raw data) ═══ -->
            <TextBlock Text="■ 全イベント (リポジトリ生データ)" FontSize="14" FontWeight="Bold" Margin="0,0,0,4" />
            <Border Background="{ThemeResource SystemControlBackgroundListLowBrush}"
                    CornerRadius="4" Padding="10" Margin="0,0,0,12">
                <TextBlock x:Name="AllEventsLabel" FontSize="11" FontFamily="Consolas"
                           TextWrapping="Wrap" IsTextSelectionEnabled="True" />
            </Border>

            <!-- ═══ Section 3: Occurrence Expansion ═══ -->
            <TextBlock Text="■ オカレンス展開結果 (today～tomorrow)" FontSize="14" FontWeight="Bold" Margin="0,0,0,4" />
            <Border Background="{ThemeResource SystemControlBackgroundListLowBrush}"
                    CornerRadius="4" Padding="10" Margin="0,0,0,12">
                <TextBlock x:Name="OccurrenceLabel" FontSize="11" FontFamily="Consolas"
                           TextWrapping="Wrap" IsTextSelectionEnabled="True" />
            </Border>

            <!-- ═══ Section 4: Alarm Engine Pipeline ═══ -->
            <TextBlock Text="■ アラームエンジン判定パイプライン" FontSize="14" FontWeight="Bold" Margin="0,0,0,4" />
            <Border Background="{ThemeResource SystemControlBackgroundListLowBrush}"
                    CornerRadius="4" Padding="10" Margin="0,0,0,12">
                <TextBlock x:Name="EngineDiagLabel" FontSize="11" FontFamily="Consolas"
                           TextWrapping="Wrap" IsTextSelectionEnabled="True" />
            </Border>

            <!-- ═══ Section 5: Fired Keys ═══ -->
            <TextBlock Text="■ 発火済キー一覧" FontSize="14" FontWeight="Bold" Margin="0,0,0,4" />
            <Border Background="{ThemeResource SystemControlBackgroundListLowBrush}"
                    CornerRadius="4" Padding="10" Margin="0,0,0,12">
                <TextBlock x:Name="FiredKeysLabel" FontSize="11" FontFamily="Consolas"
                           TextWrapping="Wrap" IsTextSelectionEnabled="True" />
            </Border>

            <!-- ═══ Section 6: Scheduled Alarm Cards ═══ -->
            <TextBlock Text="■ スケジュール済アラーム" FontSize="14" FontWeight="Bold" Margin="0,0,0,4" />
            <ListView x:Name="AlarmList" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="12" Margin="0,4">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="Bold" />
                                    <TextBlock Text="{Binding StatusBadge}" FontSize="15"
                                               Foreground="{Binding StatusBrush}" Margin="4,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="{Binding Detail}" FontSize="13"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                                <TextBlock Text="{Binding NotifyAtText}" FontSize="12"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </StackPanel>
    </ScrollViewer>

</Window>
