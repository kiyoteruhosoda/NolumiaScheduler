<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NolumiaScheduler.Presentation.Pages.AlarmNotificationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Alarm">

    <Grid Background="#E0101010">

        <!-- Centered card -->
        <Border Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                CornerRadius="16" Padding="32,40"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="460" MinWidth="360">

            <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">

                <FontIcon x:Name="AppIcon" Glyph="&#xEA8F;" FontSize="48" HorizontalAlignment="Center" />

                <TextBlock x:Name="TitleLabel" FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />

                <TextBlock x:Name="MessageLabel" FontSize="16"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

                <TextBlock x:Name="TimeLabel" FontSize="13"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" />

                <Button x:Name="OpenLocationBtn" FontSize="14"
                        Height="44" HorizontalAlignment="Stretch"
                        Click="OnOpenLocationClicked"
                        Visibility="Collapsed" />

                <Rectangle Height="1" Fill="{ThemeResource SystemControlForegroundBaseLowBrush}" Margin="0,8" />

                <Button x:Name="DismissBtn" FontSize="18"
                        Height="52" HorizontalAlignment="Stretch"
                        Click="OnDismissClicked"
                        Style="{ThemeResource AccentButtonStyle}" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0" x:Name="Snooze5Btn" FontSize="13"
                            Height="44" HorizontalAlignment="Stretch"
                            Click="OnSnooze5Clicked" />
                    <Button Grid.Column="1" x:Name="Snooze1Btn" FontSize="13"
                            Height="44" HorizontalAlignment="Stretch"
                            Click="OnSnooze1Clicked" />
                </Grid>

                <Grid x:Name="BeforeEventGrid" ColumnDefinitions="*,*" ColumnSpacing="12" Visibility="Collapsed">
                    <Button Grid.Column="0" x:Name="Before5Btn" FontSize="13"
                            Height="44" HorizontalAlignment="Stretch"
                            Click="OnSnoozeTo5MinBeforeClicked" />
                    <Button Grid.Column="1" x:Name="Before1Btn" FontSize="13"
                            Height="44" HorizontalAlignment="Stretch"
                            Click="OnSnoozeTo1MinBeforeClicked" />
                </Grid>

                <Button x:Name="CancelAllBtn" FontSize="13"
                        Height="44" HorizontalAlignment="Stretch"
                        Click="OnCancelAllClicked"
                        Foreground="#FF4444" />

            </StackPanel>
        </Border>
    </Grid>

</Window>
