<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NolumiaScheduler.WinUI.Presentation.Pages.AlarmNotificationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Alarm">

    <Grid Background="{StaticResource GCalAlarmScrim}">

        <!-- Centered card -->
        <Border Background="{ThemeResource GCalSurface}"
                BorderBrush="{ThemeResource GCalBorder}" BorderThickness="1"
                CornerRadius="24" Padding="40,44,40,32"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="440" MinWidth="380">

            <StackPanel Spacing="0" HorizontalAlignment="Stretch">

                <!-- Bell in a soft accent circle -->
                <Border Width="80" Height="80" CornerRadius="40"
                        Background="{StaticResource GCalAlarmBadgeTint}"
                        HorizontalAlignment="Center">
                    <FontIcon x:Name="AppIcon" Glyph="&#xEA8F;" FontSize="36"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="{StaticResource GCalBlue}"/>
                </Border>

                <!-- Current time, quiet, right under the badge -->
                <TextBlock x:Name="TimeLabel" FontSize="12" Margin="0,16,0,4"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           CharacterSpacing="60"
                           Foreground="{ThemeResource GCalTextSecondary}"/>

                <!-- Event title -->
                <TextBlock x:Name="TitleLabel" FontSize="22" FontWeight="SemiBold"
                           Margin="0,4,0,0" MaxLines="2"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                           Foreground="{ThemeResource GCalTextPrimary}"/>

                <!-- Alarm message -->
                <TextBlock x:Name="MessageLabel" FontSize="14" Margin="0,8,0,0"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                           Foreground="{ThemeResource GCalTextSecondary}"/>

                <!-- Location (only when set) -->
                <Button x:Name="OpenLocationBtn" FontSize="13" Margin="0,16,0,0"
                        Height="40" HorizontalAlignment="Center" Padding="20,0"
                        CornerRadius="20" Background="Transparent"
                        BorderBrush="{ThemeResource GCalBorder}"
                        Click="OnOpenLocationClicked"
                        Visibility="Collapsed"/>

                <!-- Primary action -->
                <Button x:Name="DismissBtn" FontSize="16" FontWeight="SemiBold"
                        Margin="0,28,0,0" Height="52" CornerRadius="26"
                        HorizontalAlignment="Stretch"
                        Click="OnDismissClicked"
                        Style="{ThemeResource AccentButtonStyle}"/>

                <!-- Snooze row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,12,0,0">
                    <Button Grid.Column="0" x:Name="Snooze5Btn" FontSize="13"
                            Height="44" CornerRadius="22" HorizontalAlignment="Stretch"
                            Background="{ThemeResource GCalSurfaceVariant}"
                            BorderBrush="{ThemeResource GCalBorder}"
                            Click="OnSnooze5Clicked"/>
                    <Button Grid.Column="1" x:Name="Snooze1Btn" FontSize="13"
                            Height="44" CornerRadius="22" HorizontalAlignment="Stretch"
                            Background="{ThemeResource GCalSurfaceVariant}"
                            BorderBrush="{ThemeResource GCalBorder}"
                            Click="OnSnooze1Clicked"/>
                </Grid>

                <!-- Before-event snooze row (only for pre-start alarms) -->
                <Grid x:Name="BeforeEventGrid" ColumnDefinitions="*,*" ColumnSpacing="10"
                      Margin="0,10,0,0" Visibility="Collapsed">
                    <Button Grid.Column="0" x:Name="Before5Btn" FontSize="13"
                            Height="44" CornerRadius="22" HorizontalAlignment="Stretch"
                            Background="{ThemeResource GCalSurfaceVariant}"
                            BorderBrush="{ThemeResource GCalBorder}"
                            Click="OnSnoozeTo5MinBeforeClicked"/>
                    <Button Grid.Column="1" x:Name="Before1Btn" FontSize="13"
                            Height="44" CornerRadius="22" HorizontalAlignment="Stretch"
                            Background="{ThemeResource GCalSurfaceVariant}"
                            BorderBrush="{ThemeResource GCalBorder}"
                            Click="OnSnoozeTo1MinBeforeClicked"/>
                </Grid>

                <!-- Cancel-all: quiet text button, deliberately last and small -->
                <Button x:Name="CancelAllBtn" FontSize="12"
                        Margin="0,16,0,0" Height="36" Padding="16,0"
                        HorizontalAlignment="Center"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource GCalRed}"
                        Click="OnCancelAllClicked"/>

            </StackPanel>
        </Border>
    </Grid>

</Window>
