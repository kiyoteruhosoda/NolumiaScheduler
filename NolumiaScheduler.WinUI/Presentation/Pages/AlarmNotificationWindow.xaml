<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NolumiaScheduler.WinUI.Presentation.Pages.AlarmNotificationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Alarm">

    <Grid Background="{StaticResource GCalAlarmScrim}">

        <!-- Centered card -->
        <Border Background="{ThemeResource GCalSurface}"
                BorderBrush="{ThemeResource GCalBorder}" BorderThickness="1"
                CornerRadius="24" Padding="40,44,40,32"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="440" MinWidth="380" MaxHeight="900">

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
            <StackPanel Spacing="0" HorizontalAlignment="Stretch">

                <!-- Bell in a soft accent circle -->
                <Border Width="80" Height="80" CornerRadius="40"
                        Background="{StaticResource GCalAlarmBadgeTint}"
                        HorizontalAlignment="Center">
                    <FontIcon x:Name="AppIcon" Glyph="&#xEA8F;" FontSize="36"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="{StaticResource GCalBlue}"/>
                </Border>

                <!-- Current time, quiet, right under the badge -->
                <TextBlock x:Name="TimeLabel" FontSize="12" Margin="0,16,0,4"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           CharacterSpacing="60"
                           Foreground="{ThemeResource GCalTextSecondary}"/>

                <!-- Event title -->
                <TextBlock x:Name="TitleLabel" FontSize="22" FontWeight="SemiBold"
                           Margin="0,4,0,0" MaxLines="2"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                           Foreground="{ThemeResource GCalTextPrimary}"/>

                <!-- Alarm message -->
                <TextBlock x:Name="MessageLabel" FontSize="14" Margin="0,8,0,0"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                           Foreground="{ThemeResource GCalTextSecondary}"/>

                <!-- Next alarm countdown -->
                <TextBlock x:Name="NextAlarmLabel" FontSize="13" Margin="0,12,0,0"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                           Foreground="{ThemeResource GCalTextSecondary}"/>

                <!-- Location (only when set) -->
                <Button x:Name="OpenLocationBtn" FontSize="13" Margin="0,16,0,0"
                        Height="40" HorizontalAlignment="Center" Padding="20,0"
                        CornerRadius="20" Background="Transparent"
                        BorderBrush="{ThemeResource GCalBorder}"
                        Click="OnOpenLocationClicked"
                        Visibility="Collapsed"/>

                <!-- Pre-event offset toggles (5 min / 1 min) -->
                <TextBlock x:Name="OffsetsHeaderLabel" FontSize="12" FontWeight="SemiBold"
                           Margin="0,24,0,6" CharacterSpacing="40"
                           Foreground="{ThemeResource GCalTextSecondary}"/>
                <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0" MinHeight="48">
                    <TextBlock x:Name="Toggle5Label" Grid.Column="0" FontSize="14"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource GCalTextPrimary}"/>
                    <ToggleSwitch x:Name="Toggle5Switch" Grid.Column="1" MinWidth="0"
                                  VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
                <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0" MinHeight="48">
                    <TextBlock x:Name="Toggle1Label" Grid.Column="0" FontSize="14"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource GCalTextPrimary}"/>
                    <ToggleSwitch x:Name="Toggle1Switch" Grid.Column="1" MinWidth="0"
                                  VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>

                <!-- Set next alarm time via free numeric input -->
                <TextBlock x:Name="SetNextHeaderLabel" FontSize="12" FontWeight="SemiBold"
                           Margin="0,20,0,6" CharacterSpacing="40"
                           Foreground="{ThemeResource GCalTextSecondary}"/>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" Margin="0,2,0,0">
                    <TextBlock x:Name="FromNowLabel" Grid.Column="0" FontSize="14"
                               VerticalAlignment="Center" TextWrapping="Wrap"
                               Foreground="{ThemeResource GCalTextPrimary}"/>
                    <NumberBox x:Name="FromNowInput" Grid.Column="1" Width="110" Height="48"
                               VerticalAlignment="Center"
                               Minimum="1" Maximum="1440" Value="5"
                               SmallChange="1" LargeChange="5"
                               SpinButtonPlacementMode="Inline"/>
                    <Button x:Name="FromNowSetBtn" Grid.Column="2" FontSize="13"
                            Height="48" MinWidth="72" CornerRadius="24"
                            VerticalAlignment="Center"
                            Background="{ThemeResource GCalSurfaceVariant}"
                            BorderBrush="{ThemeResource GCalBorder}"
                            Click="OnSetFromNowClicked"/>
                </Grid>
                <Grid x:Name="BeforeStartGrid" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10"
                      Margin="0,10,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="BeforeStartLabel" Grid.Column="0" FontSize="14"
                               VerticalAlignment="Center" TextWrapping="Wrap"
                               Foreground="{ThemeResource GCalTextPrimary}"/>
                    <NumberBox x:Name="BeforeStartInput" Grid.Column="1" Width="110" Height="48"
                               VerticalAlignment="Center"
                               Minimum="1" Maximum="1440" Value="5"
                               SmallChange="1" LargeChange="5"
                               SpinButtonPlacementMode="Inline"/>
                    <Button x:Name="BeforeStartSetBtn" Grid.Column="2" FontSize="13"
                            Height="48" MinWidth="72" CornerRadius="24"
                            VerticalAlignment="Center"
                            Background="{ThemeResource GCalSurfaceVariant}"
                            BorderBrush="{ThemeResource GCalBorder}"
                            Click="OnSetBeforeStartClicked"/>
                </Grid>

                <!-- Primary action -->
                <Button x:Name="DismissBtn" FontSize="16" FontWeight="SemiBold"
                        Margin="0,28,0,0" Height="52" CornerRadius="26"
                        HorizontalAlignment="Stretch"
                        Click="OnDismissClicked"
                        Style="{ThemeResource AccentButtonStyle}"/>

                <!-- Cancel-all: quiet text button, deliberately last and small -->
                <Button x:Name="CancelAllBtn" FontSize="12"
                        Margin="0,16,0,0" Height="36" Padding="16,0"
                        HorizontalAlignment="Center"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource GCalRed}"
                        Click="OnCancelAllClicked"/>

            </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>

</Window>
