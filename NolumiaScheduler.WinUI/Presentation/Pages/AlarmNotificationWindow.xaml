<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NolumiaScheduler.Presentation.Pages.AlarmNotificationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="アラーム通知">

    <Grid Background="#E0101010">

        <!-- Centered card -->
        <Border Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                CornerRadius="16" Padding="32,40"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="460" MinWidth="360">


            <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">

                <TextBlock Text="&#x1F514;" FontSize="56" HorizontalAlignment="Center" />

                <TextBlock x:Name="TitleLabel" FontSize="24" FontWeight="Bold"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />

                <TextBlock x:Name="MessageLabel" FontSize="16"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />

                <TextBlock x:Name="TimeLabel" FontSize="13"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" />

                <Button x:Name="OpenLocationBtn" Content="&#x1F4CD; ロケーションを開く" FontSize="14"
                        Height="44" HorizontalAlignment="Stretch"
                        Click="OnOpenLocationClicked"
                        Visibility="Collapsed" />

                <Rectangle Height="1" Fill="{ThemeResource SystemControlForegroundBaseLowBrush}" Margin="0,8" />

                <Button x:Name="DismissBtn" Content="閉じる" FontSize="18"
                        Height="52" HorizontalAlignment="Stretch"
                        Click="OnDismissClicked"
                        Style="{ThemeResource AccentButtonStyle}" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0" x:Name="Snooze5Btn" Content="5分後に再通知" FontSize="13"
                            Height="44" HorizontalAlignment="Stretch"
                            Click="OnSnooze5Clicked" />
                    <Button Grid.Column="1" x:Name="Snooze1Btn" Content="1分後に再通知" FontSize="13"
                            Height="44" HorizontalAlignment="Stretch"
                            Click="OnSnooze1Clicked" />
                </Grid>

            </StackPanel>
        </Border>
    </Grid>

</Window>
