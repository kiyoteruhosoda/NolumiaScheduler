<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="NolumiaScheduler.WinUI.Presentation.Pages.BusinessCalendarListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:res="using:NolumiaScheduler.Resources.Strings"
      xmlns:vm="using:NolumiaScheduler.Presentation.ViewModels"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- List -->
        <ScrollViewer Background="{ThemeResource GCalSurface}">
            <ItemsControl x:Name="CalendarList" Background="{ThemeResource GCalSurface}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:BusinessCalendarSummary">
                        <Grid Padding="16,14" MinHeight="64" ColumnDefinitions="*,24"
                              Background="{ThemeResource GCalSurface}"
                              Tapped="OnCalendarItemTapped">
                            <StackPanel Grid.Column="0" Spacing="3" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{ThemeResource GCalTextPrimary}"/>
                                <TextBlock Text="{Binding WorkdaysSummary}" FontSize="12"
                                           Foreground="{ThemeResource GCalTextSecondary}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="&#x203A;" FontSize="20"
                                       Foreground="{ThemeResource GCalTextSecondary}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            <Rectangle Grid.ColumnSpan="2" VerticalAlignment="Bottom"
                                       Height="0.5" Fill="{ThemeResource GCalBorder}"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <TextBlock x:Name="EmptyLabel" Visibility="Collapsed"
                   FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="32" Foreground="{ThemeResource GCalTextSecondary}"/>

        <!-- FAB: Add Calendar -->
        <Button x:Name="AddBtn" Width="56" Height="56" CornerRadius="28"
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="20"
                Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                Background="{StaticResource GCalBlue}" Foreground="{StaticResource GCalWhite}"
                Click="OnAddCalendarClicked">
            <FontIcon Glyph="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="20"/>
        </Button>
    </Grid>
</Page>
