<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="NolumiaScheduler.WinUI.Presentation.Pages.BusinessCalendarListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:res="using:NolumiaScheduler.Resources.Strings"
      xmlns:vm="using:NolumiaScheduler.Presentation.ViewModels"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <!-- List: card layout — only a handful of calendars are expected, so each
             entry gets a roomy card instead of a dense table row. -->
        <ScrollViewer>
            <ItemsControl x:Name="CalendarList" Padding="16,16,16,96" MaxWidth="560"
                          HorizontalAlignment="Stretch">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:BusinessCalendarSummary">
                        <Grid Margin="0,0,0,12" Padding="20,18" MinHeight="88"
                              ColumnDefinitions="Auto,*,24"
                              Background="{ThemeResource GCalSurface}"
                              BorderBrush="{ThemeResource GCalBorder}" BorderThickness="1"
                              CornerRadius="8"
                              Tapped="OnCalendarItemTapped">
                            <FontIcon Grid.Column="0" Glyph="&#xE787;"
                                      FontFamily="Segoe Fluent Icons" FontSize="22"
                                      Foreground="{StaticResource GCalBlue}"
                                      VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{ThemeResource GCalTextPrimary}"/>
                                <TextBlock Text="{Binding WorkdaysSummary}" FontSize="13"
                                           Foreground="{ThemeResource GCalTextSecondary}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="&#x203A;" FontSize="20"
                                       Foreground="{ThemeResource GCalTextSecondary}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <TextBlock x:Name="EmptyLabel" Visibility="Collapsed"
                   FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="32" Foreground="{ThemeResource GCalTextSecondary}"/>

        <!-- FAB: Add Calendar -->
        <Button x:Name="AddBtn" Width="56" Height="56" CornerRadius="28"
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="20"
                Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                Background="{StaticResource GCalBlue}" Foreground="{StaticResource GCalWhite}"
                Click="OnAddCalendarClicked">
            <FontIcon Glyph="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="20"/>
        </Button>
    </Grid>
</Page>
