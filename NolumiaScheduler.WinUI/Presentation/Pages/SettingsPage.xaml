<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NolumiaScheduler.WinUI.Presentation.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="20" MaxWidth="480" HorizontalAlignment="Left">

            <TextBlock x:Name="PageTitleText"
                       Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,4"/>

            <!-- Theme -->
            <StackPanel Spacing="8">
                <TextBlock x:Name="ThemeLabelText"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <ComboBox x:Name="ThemePicker"
                          MinWidth="200"
                          SelectionChanged="OnThemeSelectionChanged"/>
            </StackPanel>

            <!-- Language -->
            <StackPanel Spacing="8">
                <TextBlock x:Name="LanguageLabelText"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <ComboBox x:Name="LanguagePicker"
                          MinWidth="200"
                          SelectionChanged="OnLanguageSelectionChanged"/>
            </StackPanel>

            <!-- Startup view -->
            <StackPanel Spacing="8">
                <TextBlock x:Name="StartupViewLabelText"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <ComboBox x:Name="StartupViewPicker"
                          MinWidth="200"
                          SelectionChanged="OnStartupViewSelectionChanged"/>
            </StackPanel>

            <!-- Version (git describe + build time, stamped at build) -->
            <StackPanel Spacing="8">
                <TextBlock x:Name="VersionLabelText"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBlock x:Name="VersionValueText"
                           IsTextSelectionEnabled="True"
                           Style="{StaticResource BodyTextBlockStyle}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
