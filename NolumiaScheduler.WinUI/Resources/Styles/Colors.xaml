<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="GCalSurface"         Color="#ffffff"/>
            <SolidColorBrush x:Key="GCalSurfaceVariant"  Color="#f8f9fa"/>
            <SolidColorBrush x:Key="GCalTextPrimary"     Color="#202124"/>
            <SolidColorBrush x:Key="GCalTextSecondary"   Color="#70757a"/>
            <SolidColorBrush x:Key="GCalBorder"          Color="#e0e0e0"/>
            <SolidColorBrush x:Key="GCalOutOfMonthText"  Color="#bdbdbd"/>
            <SolidColorBrush x:Key="GCalHolidayBg"       Color="#fff0f0"/>
            <SolidColorBrush x:Key="GCalSundayBg"        Color="#fff8f8"/>
            <SolidColorBrush x:Key="GCalSaturdayBg"      Color="#f0f4ff"/>
            <SolidColorBrush x:Key="GCalEventMovedTheme" Color="#9c27b0"/>
            <!-- Week grid canvas colors -->
            <SolidColorBrush x:Key="GCalGridLine"        Color="#D0D7DE"/>
            <SolidColorBrush x:Key="GCalGridHalfLine"    Color="#5AD0D7DE"/>
            <SolidColorBrush x:Key="GCalCurrentTimeLine" Color="#EA4335"/>
            <SolidColorBrush x:Key="GCalAllDayTint"      Color="#301A73E8"/>
            <SolidColorBrush x:Key="GCalDragGhost"       Color="#5A1A73E8"/>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="GCalSurface"         Color="#1e1e1e"/>
            <SolidColorBrush x:Key="GCalSurfaceVariant"  Color="#2d2d2d"/>
            <SolidColorBrush x:Key="GCalTextPrimary"     Color="#ffffff"/>
            <SolidColorBrush x:Key="GCalTextSecondary"   Color="#9aa0a6"/>
            <SolidColorBrush x:Key="GCalBorder"          Color="#3c3c3c"/>
            <SolidColorBrush x:Key="GCalOutOfMonthText"  Color="#555555"/>
            <SolidColorBrush x:Key="GCalHolidayBg"       Color="#3a1a1a"/>
            <SolidColorBrush x:Key="GCalSundayBg"        Color="#2d1a1a"/>
            <SolidColorBrush x:Key="GCalSaturdayBg"      Color="#1a1a2d"/>
            <SolidColorBrush x:Key="GCalEventMovedTheme" Color="#ce93d8"/>
            <!-- Week grid canvas colors -->
            <SolidColorBrush x:Key="GCalGridLine"        Color="#454545"/>
            <SolidColorBrush x:Key="GCalGridHalfLine"    Color="#50454545"/>
            <SolidColorBrush x:Key="GCalCurrentTimeLine" Color="#EA4335"/>
            <SolidColorBrush x:Key="GCalAllDayTint"      Color="#301A73E8"/>
            <SolidColorBrush x:Key="GCalDragGhost"       Color="#5A1A73E8"/>
        </ResourceDictionary>

        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="GCalSurface"         Color="{ThemeResource SystemColorWindowColor}"/>
            <SolidColorBrush x:Key="GCalSurfaceVariant"  Color="{ThemeResource SystemColorWindowColor}"/>
            <SolidColorBrush x:Key="GCalTextPrimary"     Color="{ThemeResource SystemColorWindowTextColor}"/>
            <SolidColorBrush x:Key="GCalTextSecondary"   Color="{ThemeResource SystemColorGrayTextColor}"/>
            <SolidColorBrush x:Key="GCalBorder"          Color="{ThemeResource SystemColorButtonTextColor}"/>
            <SolidColorBrush x:Key="GCalOutOfMonthText"  Color="{ThemeResource SystemColorGrayTextColor}"/>
            <SolidColorBrush x:Key="GCalHolidayBg"       Color="{ThemeResource SystemColorWindowColor}"/>
            <SolidColorBrush x:Key="GCalSundayBg"        Color="{ThemeResource SystemColorWindowColor}"/>
            <SolidColorBrush x:Key="GCalSaturdayBg"      Color="{ThemeResource SystemColorWindowColor}"/>
            <SolidColorBrush x:Key="GCalEventMovedTheme" Color="{ThemeResource SystemColorHighlightColor}"/>
            <!-- Week grid canvas colors -->
            <SolidColorBrush x:Key="GCalGridLine"        Color="{ThemeResource SystemColorButtonTextColor}"/>
            <SolidColorBrush x:Key="GCalGridHalfLine"    Color="{ThemeResource SystemColorButtonTextColor}"/>
            <SolidColorBrush x:Key="GCalCurrentTimeLine" Color="{ThemeResource SystemColorHighlightColor}"/>
            <SolidColorBrush x:Key="GCalAllDayTint"      Color="{ThemeResource SystemColorHighlightColor}"/>
            <SolidColorBrush x:Key="GCalDragGhost"       Color="{ThemeResource SystemColorHighlightColor}"/>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- Static colors (same in all themes) -->
    <SolidColorBrush x:Key="GCalBlue"           Color="#1a73e8"/>
    <SolidColorBrush x:Key="GCalRed"            Color="#d93025"/>
    <SolidColorBrush x:Key="GCalGreen"          Color="#1e8e3e"/>
    <SolidColorBrush x:Key="GCalEventMoved"     Color="#9c27b0"/>
    <SolidColorBrush x:Key="GCalWhite"          Color="#ffffff"/>
    <SolidColorBrush x:Key="GCalSelectedCircle" Color="#70757a"/>
    <!-- Dim backdrop behind the full-screen alarm card; semi-transparent so the
         desktop shows through the layered overlay window -->
    <SolidColorBrush x:Key="GCalAlarmScrim"     Color="#D9101014"/>
    <!-- Soft accent tint for the alarm bell badge -->
    <SolidColorBrush x:Key="GCalAlarmBadgeTint"    Color="#221A73E8"/>
    <!-- Red tint for elapsed-time badge (event has started) -->
    <SolidColorBrush x:Key="GCalAlarmElapsedTint"  Color="#22D93025"/>

</ResourceDictionary>
