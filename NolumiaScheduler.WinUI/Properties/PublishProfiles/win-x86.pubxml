<?xml version="1.0" encoding="utf-8"?>
<!--
  Folder publish profile for the self-contained, unpackaged WinUI build targeting win-x86.
  Visual Studio's publish wizard requires a .pubxml file for desktop (non-web) projects;
  without one it falls back to the WebTools infrastructure which is not designed for WinUI
  apps and fails with a generic WebToolsException.
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x86</Platform>
    <PublishProtocol>FileSystem</PublishProtocol>
    <PublishDir>bin\publish\win-x86\</PublishDir>
    <RuntimeIdentifier>win-x86</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <PublishSingleFile>false</PublishSingleFile>
  </PropertyGroup>
</Project>
