<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NolumiaScheduler.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NolumiaScheduler.WinUI"
    Title="NolumiaScheduler">

    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>

    <NavigationView x:Name="NavView"
                    PaneDisplayMode="Left"
                    IsBackButtonVisible="Visible"
                    IsBackEnabled="{x:Bind CanGoBack, Mode=OneWay}"
                    BackRequested="OnBackRequested"
                    SelectionChanged="OnNavSelectionChanged"
                    IsPaneToggleButtonVisible="True"
                    IsPaneOpen="False">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="MonthNavItem" Tag="Month">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE787;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="WeekNavItem" Tag="Week">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8BF;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem x:Name="BusinessCalendarNavItem" Tag="BusinessCalendars">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE736;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem x:Name="DebugNavItem" Tag="Debug" Content="Alarm Debug">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xEBE8;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <Frame x:Name="ContentFrame" NavigationFailed="OnNavigationFailed"/>
    </NavigationView>
</Window>
